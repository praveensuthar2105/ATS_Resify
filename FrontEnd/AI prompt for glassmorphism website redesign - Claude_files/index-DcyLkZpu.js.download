lugin-skill"===e.itemType&&(a+=1),a}function Hne(e,t,s){const{data:a,isLoading:n}=bL(),r=fE(),i=mg(),{data:o}=FN(),l=function(){const e=xC();return(0,Lne.useMemo)(()=>[{id:"eng-code-review-checklist",title:e.formatMessage({defaultMessage:"Create a code review checklist for my team",id:"jruUFflBib"}),category:"create",itemType:"static",workFunction:"Engineering",prompt:e.formatMessage({defaultMessage:"I want to create a code review checklist for my team. Give me space to share our tech stack, team size, and the common issues we run into. I might have an existing checklist or team guidelines to build from. Check if my GitHub is connected since it could help pull in context from our repos. Follow up on anything that\u2019s unclear, then draft a structured checklist covering correctness, security, performance, and maintainability for us to review and refine.",id:"bkZZpvlM7i"}),tags:["code review","checklist","engineering","best practices"],optionalConnectors:[$.GITHUB]},{id:"eng-architecture-doc",title:e.formatMessage({defaultMessage:"Draft an architecture design doc",id:"kbBStXwEug"}),category:"create",itemType:"static",workFunction:"Engineering",prompt:e.formatMessage({defaultMessage:"I want to write an architecture design doc. I\u2019ll lay out the system, the problem it solves, and the constraints I\u2019m working with. Check if GitHub\u2019s connected too, it could help pull in code for context. Once that\u2019s down, help me think through the trade-offs. Only start drafting once we\u2019ve agreed on the approach.",id:"pPyHeUidXc"}),tags:["architecture","design doc","RFC","system design","engineering"],optionalConnectors:[$.GITHUB]},{id:"eng-incident-postmortem",title:e.formatMessage({defaultMessage:"Write an incident postmortem",id:"UmFb7Pj0mj"}),category:"communicate",itemType:"static",workFunction:"Engineering",prompt:e.formatMessage({defaultMessage:"I want to write a postmortem for a recent incident. Let me share what happened: the timeline, impact, and what we know so far. I might have a template or past postmortem to follow. Follow up on anything that\u2019s unclear, then draft a postmortem with root cause analysis, impact summary, and action items to prevent recurrence.",id:"A4husqdL6G"}),tags:["incident","postmortem","root cause","engineering","SRE"]},{id:"eng-technical-documentation",title:e.formatMessage({defaultMessage:"Write technical documentation",id:"lfN1IFcyuE"}),category:"create",itemType:"static",workFunction:"Engineering",prompt:e.formatMessage({defaultMessage:"I want to write technical documentation. Give me space to share what I\u2019m documenting: the system, API, or process, and who the audience is. Check if my GitHub is connected since it could help pull in existing code for context. Follow up on anything that\u2019s unclear, then draft clear, structured documentation we can refine together.",id:"UOFjwfOvsK"}),tags:["technical writing","documentation","engineering","docs","README"],optionalConnectors:[$.GITHUB]},{id:"hr-job-description",title:e.formatMessage({defaultMessage:"Write a job description",id:"L4bo/l7Iab"}),category:"create",itemType:"static",workFunction:"Human Resources",prompt:e.formatMessage({defaultMessage:"I want to write a job description. Let me tell you about the role: the team, level, and what we\u2019re looking for. I might have an existing posting or format to match. Follow up on anything that\u2019s unclear, then draft a job posting with responsibilities, qualifications, and what makes the team worth joining.",id:"IxKcq3FghG"}),tags:["hiring","job posting","recruiting","talent","JD"]},{id:"hr-onboarding-plan",title:e.formatMessage({defaultMessage:"Build a new hire onboarding plan",id:"0v2Vr9Piav"}),category:"organize",itemType:"static",workFunction:"Human Resources",prompt:e.formatMessage({defaultMessage:"I want to build an onboarding plan for a new hire. Give me space to share the details: the role, team, and start date. I might have existing onboarding docs to build on. Follow up on anything that\u2019s unclear, then create a structured 30-60-90 day plan with week-by-week milestones, key meetings to schedule, and resources to share.",id:"tTKDe13UIi"}),tags:["onboarding","new hire","30-60-90","HR","plan"]},{id:"hr-performance-review",title:e.formatMessage({defaultMessage:"Draft a performance review",id:"qWXpmOJG3f"}),category:"communicate",itemType:"static",workFunction:"Human Resources",prompt:e.formatMessage({defaultMessage:"I want to draft a performance review. Give me space to share the details: their accomplishments, areas for growth, and any specific feedback I want to include. I might have a template or past review to reference. Follow up on anything that\u2019s unclear, then draft a balanced review with clear examples and actionable development goals for us to refine.",id:"sukQFMR9O4"}),tags:["performance review","feedback","development","HR","evaluation"]},{id:"marketing-campaign-brief",title:e.formatMessage({defaultMessage:"Write a campaign brief",id:"52MPjA+HTk"}),category:"create",itemType:"static",workFunction:"Marketing",prompt:e.formatMessage({defaultMessage:"I want to write a campaign brief. Give me room to share what I\u2019m thinking: the product, audience, goals, and channels I have in mind. Once that\u2019s down, help me sharpen the strategy with follow-up questions. Only start drafting once we\u2019ve aligned on the messaging and approach.",id:"ZF5tRge4nx"}),tags:["campaign","brief","messaging","marketing","strategy"]},{id:"marketing-competitive-positioning",title:e.formatMessage({defaultMessage:"Develop competitive positioning",id:"Le9XcqzVrP"}),category:"analyze",itemType:"static",workFunction:"Marketing",prompt:e.formatMessage({defaultMessage:"I want to develop competitive positioning. Give me space to share what I know: my product, the competitors I\u2019m watching, and where I think we stand. Once I\u2019ve laid that out, help me think through the differentiation with follow-up questions. Only start crafting positioning statements and a competitive reference sheet once we\u2019ve agreed on the angle. Then let\u2019s refine it together.",id:"2/vPKe54pT"}),tags:["positioning","competitive","messaging","competitive reference sheet","marketing"]},{id:"marketing-content-calendar",title:e.formatMessage({defaultMessage:"Build a content calendar",id:"ZNQU6OVfFn"}),category:"organize",itemType:"static",workFunction:"Marketing",prompt:e.formatMessage({defaultMessage:"I want to build a content calendar. Give me space to share our channels, audience, goals, and any upcoming launches or events. Check if my Google Drive is connected since it could help pull in existing content or planning docs. Ask follow-up questions about cadence and themes, then draft a structured calendar we can refine together.",id:"PqXDfIFl6E"}),tags:["content calendar","marketing","content strategy","planning"],optionalConnectors:[$.GDRIVE]},{id:"marketing-social-post",title:e.formatMessage({defaultMessage:"Jam on a social post",id:"2m94T/5w2D"}),category:"create",itemType:"static",workFunction:"Marketing",prompt:e.formatMessage({defaultMessage:"I want to draft a social post. Give me room to share the gist and the vibe I\u2019m going for. Follow up on anything that\u2019s unclear, then give me a few different takes so we can bounce back and forth until one lands.",id:"BWHRMufOSK"}),tags:["social","post","marketing","copywriting"]},{id:"marketing-refine-copy",title:e.formatMessage({defaultMessage:"Refine some copy",id:"5aKAejvWnO"}),category:"create",itemType:"static",workFunction:"Marketing",prompt:e.formatMessage({defaultMessage:"I want to refine some copy. Let me share what I have, what job it needs to do, and who\u2019s reading it. Follow up on anything that\u2019s unclear, then give me a few sharper takes for us to compare.",id:"49nn9ypEIP"}),tags:["copy","writing","marketing","editing"]},{id:"sales-objection-handling",title:e.formatMessage({defaultMessage:"Build an objection handling guide",id:"jch3rht5JJ"}),category:"create",itemType:"static",workFunction:"Sales",prompt:e.formatMessage({defaultMessage:"I want to build an objection handling guide for my sales team. Give me space to share our product, the common objections we hear, and our competitive advantages. I might have existing materials or CRM data to pull from. Follow up on anything that\u2019s unclear, then create a structured guide with each objection, recommended responses, and supporting proof points for us to review.",id:"9i2vO5LXLm"}),tags:["objections","sales enablement","battle card","responses"]},{id:"sales-cold-outreach",title:e.formatMessage({defaultMessage:"Draft a cold outreach sequence",id:"I3UV0VVgCr"}),category:"communicate",itemType:"static",workFunction:"Sales",prompt:e.formatMessage({defaultMessage:"I want to build a cold outreach email sequence. Give me space to share my target audience, product, and value proposition. Check if my Gmail is connected since it could help reference past outreach or communication style. Ask follow-up questions about tone, sequence length, and what\u2019s worked before. Then draft an outreach sequence we can refine together.",id:"uD9Jymk478"}),tags:["cold outreach","sales","prospecting","email sequence","pipeline"],optionalConnectors:[$.GMAIL]},{id:"sales-playbook",title:e.formatMessage({defaultMessage:"Build a sales playbook",id:"HT4uW/lZtO"}),category:"create",itemType:"static",workFunction:"Sales",prompt:e.formatMessage({defaultMessage:"I want to create a sales playbook for my team. Give me space to share our product, ideal customer profile, sales process, and common objections. Follow up on anything that\u2019s unclear, then draft a structured playbook covering discovery, demo, negotiation, and closing.",id:"/A7PzsEOMH"}),tags:["sales playbook","sales enablement","methodology","sales process"]},{id:"ops-process-documentation",title:e.formatMessage({defaultMessage:"Document a business process",id:"gZ36kLfmpe"}),category:"create",itemType:"static",workFunction:"Operations",prompt:e.formatMessage({defaultMessage:"I want to document a business process. Give me space to walk you through the process step by step. I might have existing docs or diagrams to start from. Follow up on anything that\u2019s unclear, then create clear documentation with a flowchart, decision points, responsible parties, and edge cases for us to review and refine.",id:"sHJI1xwOUk"}),tags:["SOP","process","documentation","workflow","operations"]},{id:"ops-quarterly-review",title:e.formatMessage({defaultMessage:"Prepare a quarterly business review",id:"pzYrOieJ9j"}),category:"create",itemType:"static",workFunction:"Operations",prompt:e.formatMessage({defaultMessage:"I want to prepare a quarterly business review. Give me room to share what I\u2019m thinking: the key metrics, team accomplishments, and challenges from the quarter. Once that\u2019s down, help me sharpen the narrative with follow-up questions. Only start building the quarterly review deck once we\u2019ve aligned on the story. Then let\u2019s iterate on the slides together.",id:"BkTS2roBTG"}),tags:["QBR","quarterly review","metrics","reporting","operations"]},{id:"ops-vendor-comparison",title:e.formatMessage({defaultMessage:"Compare vendors for a tool or service",id:"EzFw/5R3R/"}),category:"analyze",itemType:"static",workFunction:"Operations",prompt:e.formatMessage({defaultMessage:"I want to compare vendors for a tool or service. Give me space to share our requirements, budget, and evaluation criteria. Follow up on anything that\u2019s unclear, then research the top options and produce a comparison matrix with pricing, features, pros and cons, and a recommendation.",id:"74mp+v9Ql3"}),tags:["vendor","evaluation","comparison","procurement","RFP"]},{id:"design-user-flow",title:e.formatMessage({defaultMessage:"Map out a user flow",id:"ZP19DeE2nA"}),category:"create",itemType:"static",workFunction:"Design",prompt:e.formatMessage({defaultMessage:"I want to map out a user flow. Give me room to share what I\u2019m thinking: the feature, user goals, and entry points. Once I\u2019ve laid that out, help me think through the edge cases with follow-up questions. Only start building the flow once we\u2019ve aligned on the scope.",id:"I67OO4MrLJ"}),tags:["user flow","UX","wireframe","journey","interaction design"]},{id:"design-audit",title:e.formatMessage({defaultMessage:"Audit a page for UX issues",id:"+Pd7+psY0z"}),category:"analyze",itemType:"static",workFunction:"Design",prompt:e.formatMessage({defaultMessage:"I want to audit a page or screen for UX issues. Give me space to share the URL or screenshots. Follow up on anything that\u2019s unclear, then review it for usability problems, accessibility issues, and visual inconsistencies, and produce a prioritized list of recommendations.",id:"wYJR11Fq2y"}),tags:["UX audit","usability","accessibility","design review","heuristics"]},{id:"pm-user-research-synthesis",title:e.formatMessage({defaultMessage:"Synthesize user research into actionable insights",id:"XqM6R2Cyd6"}),category:"analyze",itemType:"static",workFunction:"Product Management",prompt:e.formatMessage({defaultMessage:"I want to synthesize user research. Let me share the research sources: interviews, surveys, usability tests, or other data. I might have interview transcripts or survey results to upload. Follow up on anything that\u2019s unclear, then identify patterns, group findings into themes, and produce a summary with prioritized recommendations and supporting quotes.",id:"i5aLEFkQMz"}),tags:["user research","insights","themes","product","synthesis"]},{id:"pm-feature-prioritization",title:e.formatMessage({defaultMessage:"Prioritize a feature backlog",id:"ghn1Se5b0Q"}),category:"analyze",itemType:"static",workFunction:"Product Management",prompt:e.formatMessage({defaultMessage:"I want to prioritize my feature backlog. Give me space to share the features we\u2019re considering, our goals, and any constraints. Check if my Asana or Slack are connected since they could help pull in existing tasks and context. Ask follow-up questions about impact, effort, and dependencies. Then help me build a prioritized framework we can review together.",id:"HTdil0l/u5"}),tags:["feature prioritization","product","backlog","roadmap","planning"],optionalConnectors:[$.ASANA,$.SLACK]},{id:"pm-product-launch",title:e.formatMessage({defaultMessage:"Plan a product launch",id:"ZA4EGivvbV"}),category:"organize",itemType:"static",workFunction:"Product Management",prompt:e.formatMessage({defaultMessage:"I want to plan a product launch. Give me space to share what we\u2019re launching, the timeline, and who\u2019s involved. Check if my Slack or Google Drive are connected since they could help pull in existing planning docs and team context. Follow up on anything that\u2019s unclear, then draft a launch plan with milestones, owners, and a checklist to track.",id:"XphQYURImA"}),tags:["product launch","product","go-to-market","launch plan","milestones"],optionalConnectors:[$.SLACK,$.GDRIVE]},{id:"ds-ab-test-analysis",title:e.formatMessage({defaultMessage:"Analyze an A/B test",id:"Xmz+hqJFU1"}),category:"analyze",itemType:"static",workFunction:"Data Science",prompt:e.formatMessage({defaultMessage:"I want to analyze an A/B test. Give me space to share the experiment setup, metrics, and data. I might have the raw data or experiment docs to upload. Follow up on anything that\u2019s unclear, then calculate statistical significance, effect sizes, and confidence intervals, and present a clear recommendation with supporting charts.",id:"5Rt3vREMea"}),tags:["A/B test","experiment","statistics","significance","data science"]},{id:"ds-metrics-framework",title:e.formatMessage({defaultMessage:"Design a metrics framework",id:"8/MtKup01A"}),category:"create",itemType:"static",workFunction:"Data Science",prompt:e.formatMessage({defaultMessage:"I want to design a metrics framework for a product or business area. Give me space to share the context: what we\u2019re measuring, our goals, and what data we have. Ask follow-up questions, then draft a framework with primary metrics, supporting metrics, and guardrails.",id:"JcyWhmw1yn"}),tags:["metrics","data","KPIs","framework","data science"]},{id:"ds-data-pipeline",title:e.formatMessage({defaultMessage:"Plan a data pipeline",id:"vw7NKVSZnP"}),category:"create",itemType:"static",workFunction:"Data Science",prompt:e.formatMessage({defaultMessage:"I want to plan a data pipeline. Give me space to share the data sources, transformations needed, and where the output needs to go. Follow up on requirements and constraints, then draft a pipeline design with stages, tools, and error handling.",id:"eOXVVRR7R4"}),tags:["data pipeline","data","ETL","data engineering","data science"]},{id:"build-web-app",title:e.formatMessage({defaultMessage:"Build a web app",id:"CANEi1TWcH"}),category:"create",itemType:"static",prompt:e.formatMessage({defaultMessage:"I want to build a web app. Give me room to share what I\u2019m imagining. I might have designs, wireframes, or examples of what I\u2019m going for. Once I\u2019ve laid that out, help me think through the details with follow-up questions. Only start building once we\u2019ve agreed on the scope and approach. Then let\u2019s iterate as you build it out.",id:"Y7PXDgyQop"}),tags:["coding","web app","development","software"],priority:3},{id:"presentation",title:e.formatMessage({defaultMessage:"Create a presentation",id:"71cyZuc/DW"}),category:"create",itemType:"static",prompt:e.formatMessage({defaultMessage:"I want to create a presentation. Give me space to share what I\u2019m thinking: the topic, any context, materials, or style references. Once I\u2019ve laid that out, help me sharpen the idea with follow-up questions. Only start building slides once we\u2019ve agreed on the direction and structure. Then let\u2019s iterate on the draft together.",id:"5nqzFJlB2l"}),tags:["presentation","slides","deck"],priority:3},{id:"polish-notes-into-doc",title:e.formatMessage({defaultMessage:"Polish rough notes into a document",id:"Y6hI/7Vt4J"}),category:"create",itemType:"static",prompt:e.formatMessage({defaultMessage:"I want to polish rough notes into a clean document. Let me share what I\u2019m working with: meeting notes, brainstorms, interview transcripts, or other raw material. Follow up on anything that\u2019s unclear, then draft a polished version for us to review and refine.",id:"hssKFIp36r"}),tags:["notes","document","writing","polish","cleanup"],priority:3},{id:"daily-briefing",title:e.formatMessage({defaultMessage:"Create a daily briefing",id:"YgieKqhWMt"}),category:"organize",itemType:"static",prompt:e.formatMessage({defaultMessage:"I want a daily briefing. Give me space to share what I\u2019d like to focus on. It might be a specific project, team, or just a general overview. Check which of my tools are connected: calendar, email, Slack, or others. Suggest any that might be useful. Then pull everything together and give me a clear picture of my day: what\u2019s coming up, what needs attention, and any action items I should know about. Once the briefing looks good, ask if I\u2019d like to schedule it to run automatically every morning.",id:"hV64pIts0d"}),tags:["briefing","productivity","daily","summary","calendar","morning"],optionalConnectors:[$.GCAL,$.GMAIL,$.SLACK],priority:3},{id:"doc-to-presentation",title:e.formatMessage({defaultMessage:"Turn documents into a presentation",id:"w40lYJtiOQ"}),category:"create",itemType:"static",prompt:e.formatMessage({defaultMessage:"I want to turn some documents into a presentation. Give me space to share the documents. They might be notes, reports, briefs, or a mix. Once I\u2019ve shared them, help me think through which points to highlight and how to structure the slides with follow-up questions. Only start building the deck once we\u2019ve agreed on the story and flow. Then let\u2019s iterate on the slides together.",id:"F82UO9KHGC"}),tags:["presentation","slides","deck","document","convert"],priority:2},{id:"data-dashboard",title:e.formatMessage({defaultMessage:"Build a data dashboard",id:"vlCyRgD/ji"}),category:"create",prompt:e.formatMessage({defaultMessage:"I want to build a data dashboard. Give me space to share what I\u2019m thinking: the data I want to visualize, the audience, and any examples of dashboards I like. Once that\u2019s down, help me think through the layout and metrics with follow-up questions. Only start building once we\u2019ve agreed on the approach.",id:"lPm0q5Uu3E"}),tags:["data","dashboard","visualization","charts","metrics"],itemType:"cowork",priority:2},{id:"notes-to-document",title:e.formatMessage({defaultMessage:"Turn notes into a document",id:"jkDq65+m8H"}),category:"create",prompt:e.formatMessage({defaultMessage:"I want to turn some rough notes into a clear, professional document. Let me share the notes and tell you what format I need. Follow up on anything that\u2019s unclear, then draft the document for us to review and refine.",id:"gYzJ4S8ns8"}),tags:["document","notes","writing","synthesis"],itemType:"cowork",priority:2},{id:"summarize-slack-channel",title:e.formatMessage({defaultMessage:"Summarize a Slack channel",id:"kJ+O8O4rAz"}),category:"analyze",itemType:"static",prompt:e.formatMessage({defaultMessage:"I want to summarize a Slack channel. First, make sure Slack is connected, and help me set it up if it\u2019s not. Then I\u2019ll point you at the channel and timeframe. Pull the messages and give me a clear summary: decisions made, action items, anything I should follow up on.",id:"EKqQc8A3VV"}),tags:["slack","summary","decisions","action items","catchup"],connectors:[$.SLACK],priority:2},{id:"catch-up-on-updates",title:e.formatMessage({defaultMessage:"Catch up on what I missed",id:"kFWPsYcqHC"}),category:"analyze",itemType:"static",prompt:e.formatMessage({defaultMessage:"I want to catch up on what I missed. I\u2019ll tell you what I\u2019d like to catch up on. It might be a specific project, team, or timeframe. See what\u2019s connected (Slack, email, calendar, or others) and suggest any that might help. Then pull it all together and surface what I need to know.",id:"7znJojXDwm"}),tags:["catchup","slack","summary","updates","productivity"],optionalConnectors:[$.SLACK,$.GMAIL,$.GCAL],priority:2},{id:"build-landing-page",title:e.formatMessage({defaultMessage:"Create a landing page",id:"2fAQuLV4Md"}),category:"create",itemType:"static",prompt:e.formatMessage({defaultMessage:"I want to create a landing page. Give me room to share what I\u2019m going for. I might have brand guidelines, designs, or examples I like. Once I\u2019ve laid that out, help me sharpen the direction with follow-up questions. Only start building once we\u2019ve aligned on the look and structure.",id:"l5904f/s1M"}),tags:["coding","website","landing page","design"],priority:1},{id:"turn-notes-into-website",title:e.formatMessage({defaultMessage:"Turn my notes into a website",id:"F6yFH+F75D"}),category:"create",itemType:"static",prompt:e.formatMessage({defaultMessage:"I want to turn my notes or documents into a visual website. Give me space to share what I\u2019m working with: docs, outlines, or examples of a style I like. Once that\u2019s down, help me think through the layout and design with follow-up questions. Only start building once we\u2019ve aligned on the direction.",id:"vXcuFkqI//"}),tags:["website","notes","visual","html","design"],priority:1},{id:"automate-browser-task",title:e.formatMessage({defaultMessage:"Automate a browser task",id:"qQHsVqEort"}),category:"create",itemType:"static",prompt:e.formatMessage({defaultMessage:"I want to automate something I do in the browser. Give me room to walk you through the task: the steps, the sites involved, and what I\u2019m trying to accomplish. Once I\u2019ve laid that out, help me think through the approach with follow-up questions. Only start building once we\u2019ve agreed on a plan.",id:"b7w4cSnrVh"}),tags:["browser","automation","web","scripting","workflow"],priority:1},{id:"dataset-analysis",title:e.formatMessage({defaultMessage:"Analyze a dataset",id:"ol94B0ISof"}),category:"analyze",itemType:"static",prompt:e.formatMessage({defaultMessage:"I want to analyze a dataset. Let me share the data and what I\u2019m looking to learn before you dig in. Follow up on anything that\u2019s unclear, then give me a clear summary of findings for us to review.",id:"NN2BrfCTsA"}),tags:["data","analysis","statistics","insights"],priority:1},{id:"build-dashboard",title:e.formatMessage({defaultMessage:"Build a dashboard",id:"wggprBQdDT"}),category:"create",itemType:"static",prompt:e.formatMessage({defaultMessage:"I want to build a dashboard. Give me room to share what I need: the data source, the metrics that matter, and any examples of dashboards I like. Once I\u2019ve laid that out, help me think through the layout with follow-up questions. Only start building once we\u2019ve agreed on the design. Then let\u2019s iterate as you build it out.",id:"8b7rqP5MFg"}),tags:["dashboard","visualization","data","metrics","charts"],priority:1},{id:"meeting-prep",title:e.formatMessage({defaultMessage:"Prepare for a meeting",id:"9kv08pPVQt"}),category:"organize",itemType:"static",prompt:e.formatMessage({defaultMessage:"I want to prepare for a meeting. Let me tell you which meeting and what I already know about the agenda. Then see what\u2019s connected (calendar, email, Slack, or others) and suggest any that might help pull in context. Follow up on anything that\u2019s unclear, then put together an agenda with key discussion points and open questions.",id:"iosdwMQK5Q"}),tags:["meeting","prep","agenda","planning"],optionalConnectors:[$.GCAL,$.GMAIL,$.SLACK],priority:1},{id:"plan-vacation",title:e.formatMessage({defaultMessage:"Plan a trip",id:"wA0bq8ey3k"}),category:"organize",itemType:"static",prompt:e.formatMessage({defaultMessage:"I want to plan a trip. Give me room to share where I\u2019m thinking, when, and what kind of experience I\u2019m after. Follow up on anything that\u2019s unclear, then put together a detailed itinerary for us to review and adjust.",id:"FLzX7CIj68"}),tags:["travel","planning","vacation","itinerary"],priority:1},{id:"organize-files",title:e.formatMessage({defaultMessage:"Organize my files",id:"1lasV9aLbo"}),category:"organize",itemType:"static",prompt:e.formatMessage({defaultMessage:"I want to organize my files. I\u2019ll point you at the folder and tell you what needs organizing. Follow up on anything that\u2019s unclear, then scan everything, propose a plan, and wait for my go-ahead before moving anything.",id:"zfBxIKbt+J"}),tags:["files","organization","folders","cleanup"]},{id:"automate-workflow",title:e.formatMessage({defaultMessage:"Automate a repetitive workflow",id:"xgnxzXyzaP"}),category:"create",itemType:"static",prompt:e.formatMessage({defaultMessage:"I want to automate a repetitive workflow. Give me space to walk you through what I currently do manually: the steps, the tools involved, and where it breaks down. Once that\u2019s down, help me think through the best approach with follow-up questions. Only start building once we\u2019ve agreed on a plan.",id:"G8xTq+e87p"}),tags:["coding","automation","workflow","scripting"]},{id:"prd",title:e.formatMessage({defaultMessage:"Write a product requirements doc (PRD)",id:"SjoFg/h3OJ"}),category:"create",itemType:"static",prompt:e.formatMessage({defaultMessage:"I want to write a product requirements doc (PRD). Give me room to share the feature, the problem, and any context or docs I have. Once that\u2019s down, help me sharpen the scope with follow-up questions. Only start writing once we\u2019ve aligned on the structure and key decisions.",id:"rHz7nNYVaR"}),tags:["product","requirements","planning","prd"],workFunction:"Product Management"},{id:"competitive-deck",title:e.formatMessage({defaultMessage:"Create a competitive analysis deck",id:"YEJd+Y3pwR"}),category:"create",itemType:"static",prompt:e.formatMessage({defaultMessage:"I want to create a competitive analysis deck. Give me space to share what I\u2019m working with: existing research, data, or examples of what I\u2019m going for. Once that\u2019s down, help me sharpen the framing with follow-up questions. Only start building the deck once we\u2019ve aligned on the story and structure.",id:"0Zatn9GsHG"}),tags:["competitive","analysis","presentation","strategy"],workFunction:"Marketing"},{id:"write-report",title:e.formatMessage({defaultMessage:"Write a report",id:"JVHo6csMW5"}),category:"create",itemType:"static",prompt:e.formatMessage({defaultMessage:"I want to write a report. Give me space to share what I\u2019m thinking: the topic, audience, and any source materials or examples I have. Once I\u2019ve laid that out, help me think through the structure with follow-up questions. Only start writing once we\u2019ve agreed on the outline and key points. Then let\u2019s refine the draft together.",id:"o97hqyZufJ"}),tags:["report","writing","document","analysis"]},{id:"proposal",title:e.formatMessage({defaultMessage:"Draft a proposal",id:"3vfzHWT/GI"}),category:"create",itemType:"static",prompt:e.formatMessage({defaultMessage:"I want to draft a proposal. Give me space to share the context: the project, the audience, and any background or docs I have. Once that\u2019s down, help me sharpen the argument with follow-up questions. Only start writing once we\u2019ve aligned on the structure and key points. Then let\u2019s refine it together.",id:"lbPNuGkUXP"}),tags:["proposal","business","planning","pitch"]},{id:"rfp-response",title:e.formatMessage({defaultMessage:"Respond to a request for proposal (RFP)",id:"1FZrzX7ed/"}),category:"create",itemType:"static",prompt:e.formatMessage({defaultMessage:"I want to respond to a request for proposal (RFP). Give me space to share the RFP and describe what makes us a strong fit. I might also have past proposals or examples to reference. Once I\u2019ve laid that out, help me think through the positioning with follow-up questions. Only start writing once we\u2019ve agreed on the approach. Then let\u2019s iterate on the response together.",id:"axJwpTl2Ym"}),tags:["rfp","proposal","response","business"],workFunction:"Sales"},{id:"blog-post",title:e.formatMessage({defaultMessage:"Write a blog post",id:"tPYCUshYRR"}),category:"create",itemType:"static",prompt:e.formatMessage({defaultMessage:"I want to write a blog post. Give me room to share the topic, the audience, and the tone I\u2019m going for. I might have style examples or references to work from. Follow up on anything that\u2019s unclear, then draft something we can review and refine.",id:"se+SAR1BdR"}),tags:["blog","writing","content","marketing"],workFunction:"Marketing"},{id:"pitch-deck",title:e.formatMessage({defaultMessage:"Create a pitch deck",id:"Zr+xaqyWOE"}),category:"create",itemType:"static",prompt:e.formatMessage({defaultMessage:"I want to create a pitch deck. Give me space to share what I\u2019m pitching and who to. I might have examples of a style I like or existing materials. Once that\u2019s down, help me sharpen the narrative with follow-up questions. Only start building the deck once we\u2019ve agreed on the story arc.",id:"tt6VrXmasK"}),tags:["pitch","deck","presentation","fundraising","startup"]},{id:"employee-handbook",title:e.formatMessage({defaultMessage:"Create an employee handbook",id:"squ8MIPnrJ"}),category:"create",itemType:"static",prompt:e.formatMessage({defaultMessage:"I want to create an employee handbook. Give me space to share what I\u2019m thinking: the company, existing policies, and the topics I want to cover. Once I\u2019ve laid that out, help me think through the structure with follow-up questions. Only start writing once we\u2019ve agreed on the outline and tone.",id:"ie0q8GZJoQ"}),tags:["HR","handbook","document","policy","onboarding"],workFunction:"Human Resources"},{id:"brainstorm-ideas",title:e.formatMessage({defaultMessage:"Brainstorm ideas for a project",id:"b2w8riFY9w"}),category:"create",itemType:"static",prompt:e.formatMessage({defaultMessage:"I want to brainstorm ideas for a project. Let me share what I\u2019m working on (the context, constraints, and what kind of ideas I\u2019m looking for) before you start generating. Once I\u2019ve laid that out, help me sharpen the direction with follow-up questions. Only start generating ideas once we\u2019ve agreed on what good looks like. Then let\u2019s iterate and build on the best ones together.",id:"Oxaw1Pbnna"}),tags:["brainstorm","ideation","creativity","strategy","planning"]},{id:"create-study-guide",title:e.formatMessage({defaultMessage:"Create a study guide",id:"BxxpyVdTc9"}),category:"create",itemType:"static",prompt:e.formatMessage({defaultMessage:"I want to create a study guide. Give me space to share the subject and what I need to learn. I might have course materials or notes to work from. Follow up on anything that\u2019s unclear, then put together a structured guide for us to review and refine.",id:"/4C0msLvHi"}),tags:["study","education","learning","guide","notes"]},{id:"create-design-mockup",title:e.formatMessage({defaultMessage:"Create a design or mockup",id:"BREX1OWnhY"}),category:"create",itemType:"static",prompt:e.formatMessage({defaultMessage:"I want to create a visual design or mockup. Give me space to share what I\u2019m designing. I might have wireframes, inspiration, or brand guidelines. Once I\u2019ve laid that out, help me think through the details with follow-up questions. Only start building once we\u2019ve agreed on the direction.",id:"oJhS5bRzc0"}),tags:["design","mockup","visual","UI","prototype"],workFunction:"Design"},{id:"financial-model",title:e.formatMessage({defaultMessage:"Build a financial model",id:"czWMvFbS37"}),category:"create",itemType:"static",prompt:e.formatMessage({defaultMessage:"I want to build a financial model. Give me room to share what I\u2019m thinking: the purpose of the model, existing data, assumptions, or examples. Once that\u2019s down, help me think through the structure and key drivers with follow-up questions. Only start building once we\u2019ve agreed on the approach. Then let\u2019s iterate on the model together.",id:"n7J2IrJzye"}),tags:["finance","model","spreadsheet","forecasting"],workFunction:"Finance"},{id:"market-sizing",title:e.formatMessage({defaultMessage:"Size a market opportunity",id:"AwT3inPEfe"}),category:"analyze",itemType:"static",prompt:e.formatMessage({defaultMessage:"I want to size a market opportunity. Give me space to share the product and the market I\u2019m looking at. Follow up on anything that\u2019s unclear, then build a bottoms-up and top-down estimate for us to review and refine.",id:"L8VXVxlN8T"}),tags:["market","sizing","research","strategy","TAM"],workFunction:"Marketing"},{id:"clean-normalize-data",title:e.formatMessage({defaultMessage:"Clean and normalize data",id:"A9YhA6zJx9"}),category:"analyze",itemType:"static",prompt:e.formatMessage({defaultMessage:"I want to clean and normalize a dataset. Give me space to share the data and tell you what the clean output should look like. Follow up on anything that\u2019s unclear, then process it and give me the cleaned result for us to review.",id:"B4IM7l8kSJ"}),tags:["data","cleaning","csv","spreadsheet","ETL"],workFunction:"Data Science"},{id:"sales-analysis",title:e.formatMessage({defaultMessage:"Analyze sales data",id:"iJB8tRfeVO"}),category:"analyze",itemType:"static",prompt:e.formatMessage({defaultMessage:"I want to analyze sales data. Give me space to share the data and tell you what questions I\u2019m trying to answer. Follow up on anything that\u2019s unclear, then dig in and give me key insights, trends, and recommendations for us to review.",id:"UjXOtE1D68"}),tags:["sales","analysis","dashboard","revenue"],workFunction:"Sales"},{id:"customer-feedback",title:e.formatMessage({defaultMessage:"Analyze customer feedback",id:"e1Y2iXeKQ2"}),category:"analyze",itemType:"static",prompt:e.formatMessage({defaultMessage:"I want to analyze customer feedback. Let me share the feedback and tell you what I\u2019m looking to understand. Follow up on anything that\u2019s unclear, then surface the key themes, sentiment patterns, and actionable takeaways for us to review.",id:"sUtnL7h2uR"}),tags:["customer","feedback","analysis","sentiment","voice of customer"],workFunction:"Product Management"},{id:"competitor-analysis",title:e.formatMessage({defaultMessage:"Analyze competitors",id:"IQJwlJZkRw"}),category:"analyze",itemType:"static",prompt:e.formatMessage({defaultMessage:"I want to analyze competitors. Give me space to share which competitors to look at and what I want to understand. I might have existing research to build on. Follow up on anything that\u2019s unclear, then research them and give me a structured comparison for us to review and refine.",id:"udICr937do"}),tags:["competitive","research","analysis","strategy"],workFunction:"Marketing"},{id:"due-diligence",title:e.formatMessage({defaultMessage:"Run a due diligence review",id:"4GoP2XBlcs"}),category:"analyze",itemType:"static",prompt:e.formatMessage({defaultMessage:"I want to run a due diligence review. Give me space to share details about the company or deal. I might have documents, financials, or specific areas of concern. Follow up on anything that\u2019s unclear, then produce a structured assessment for us to review and refine.",id:"ynCPZrnIPy"}),tags:["due diligence","analysis","finance","investment","M&A"],workFunction:"Finance"},{id:"research-to-spreadsheet",title:e.formatMessage({defaultMessage:"Research and compile into a spreadsheet",id:"d+WgX9UJdf"}),category:"analyze",itemType:"static",prompt:e.formatMessage({defaultMessage:"I want to research a topic and compile findings into a spreadsheet. Give me room to share what I\u2019m researching and what columns or structure I need. I might have examples or templates to match. Follow up on anything that\u2019s unclear, then research and compile the results for us to review.",id:"cU+r77kbaM"}),tags:["research","spreadsheet","data","compilation"]},{id:"research-topic",title:e.formatMessage({defaultMessage:"Research a topic and summarize findings",id:"Pp3XRDSTMn"}),category:"analyze",itemType:"static",prompt:e.formatMessage({defaultMessage:"I want to research a topic and get a clear summary. Give me space to share what I\u2019m researching and what I need to understand. Follow up on anything that\u2019s unclear, then dig in and give me a well-organized summary for us to review.",id:"3pWixtk3rg"}),tags:["research","summary","findings","analysis","report"]},{id:"analyze-drive-docs",title:e.formatMessage({defaultMessage:"Analyze Google Drive documents",id:"djFcx3krDh"}),category:"analyze",itemType:"static",prompt:e.formatMessage({defaultMessage:"I want to analyze documents in my Google Drive. First, make sure Google Drive is connected, and help me set it up if it\u2019s not. Then I\u2019ll point you at the documents. Give me a clear analysis: key findings, patterns, and anything worth flagging.",id:"X9NWM3Sogr"}),tags:["google drive","documents","analysis","summary"],connectors:[$.GDRIVE]},{id:"classify-sort-pdfs",title:e.formatMessage({defaultMessage:"Classify and sort PDFs",id:"LhQ9Hfkmnk"}),category:"organize",itemType:"static",prompt:e.formatMessage({defaultMessage:"I want to classify and sort a collection of PDFs. Give me space to share where the PDFs are and how I want them categorized. Follow up on anything that\u2019s unclear, then scan them, propose a sorting plan, and wait for my approval before moving anything.",id:"i4ptz3JKwq"}),tags:["pdf","classification","sorting","organization"]},{id:"project-tracker",title:e.formatMessage({defaultMessage:"Set up a project tracker",id:"A15aSMCktN"}),category:"organize",itemType:"static",prompt:e.formatMessage({defaultMessage:"I want to set up a project tracker. See what\u2019s connected (Slack, Asana, or others) and suggest any that might help. Then I\u2019ll tell you about the project and what I need to track. Follow up on anything that\u2019s unclear, then build something we can refine.",id:"l/G6o4Eh/P"}),tags:["project","tracker","management","planning"],optionalConnectors:[$.SLACK,$.ASANA]},{id:"launch-readiness",title:e.formatMessage({defaultMessage:"Create a launch checklist",id:"AdrsQPSq9X"}),category:"organize",itemType:"static",prompt:e.formatMessage({defaultMessage:"I want to create a launch checklist. Give me space to share what I\u2019m launching and where things stand. Follow up on anything that\u2019s unclear, then draft a comprehensive checklist for us to review and refine.",id:"mw9AhQphdA"}),tags:["launch","checklist","readiness","planning","go-to-market"],workFunction:"Product Management"},{id:"email-draft",title:e.formatMessage({defaultMessage:"Draft an email",id:"h4BXCW5i8O"}),category:"communicate",itemType:"static",prompt:e.formatMessage({defaultMessage:"I want to draft an email. Check if Gmail\u2019s connected first. Suggest it if not, but if I\u2019d rather skip that, give me room to share who it\u2019s for and what I need to say. Follow up on anything that\u2019s unclear, then write a draft we can tighten together.",id:"Pl9tv3N67v"}),tags:["email","writing","communication"],optionalConnectors:[$.GMAIL]},{id:"slack-message-draft",title:e.formatMessage({defaultMessage:"Draft a Slack message",id:"IJjxW1uZ99"}),category:"communicate",itemType:"static",prompt:e.formatMessage({defaultMessage:"I want to draft a Slack message. Check if Slack\u2019s connected first since it could help pull in context from the channel or thread. If not, give me room to share who it\u2019s for and what I need to say. Follow up on anything that\u2019s unclear, then write a draft we can tighten together.",id:"6BlVrr9upM"}),tags:["slack","message","writing","communication"],optionalConnectors:[$.SLACK]},{id:"status-update",title:e.formatMessage({defaultMessage:"Write a status update",id:"IjmJNwQkkL"}),category:"communicate",itemType:"static",prompt:e.formatMessage({defaultMessage:"I want to write a status update. Give me room to share the project, the audience, and what happened this period. I might have a past update or format to follow. Follow up on anything that\u2019s unclear, then draft something concise for us to review.",id:"ATRYDGGgau"}),tags:["status","update","reporting","project"]},{id:"meeting-followup",title:e.formatMessage({defaultMessage:"Write a meeting follow-up",id:"K5XEzbUbQT"}),category:"communicate",itemType:"static",prompt:e.formatMessage({defaultMessage:"I want to write a meeting follow-up. I\u2019ll tell you which meeting and share any notes I have. Check if calendar or email are connected since they could help pull in context. Follow up on anything that\u2019s unclear, then draft a summary with action items.",id:"aY4oykdOWG"}),tags:["meeting","followup","summary","action items"],optionalConnectors:[$.GCAL,$.GMAIL]},{id:"triage-email",title:e.formatMessage({defaultMessage:"Prioritize my inbox",id:"BemswvboZE"}),category:"organize",itemType:"static",prompt:e.formatMessage({defaultMessage:"I want to prioritize my inbox. First, make sure Gmail is connected, and help me set it up if it\u2019s not. Then pull in recent emails, sort by urgency, and give me a prioritized list with draft replies for anything that needs a response today.",id:"cj9wBexPM8"}),tags:["email","prioritize","inbox","productivity"],connectors:[$.GMAIL]},{id:"organize-calendar",title:e.formatMessage({defaultMessage:"Organize my calendar",id:"TpnhCNkRb9"}),category:"organize",itemType:"static",prompt:e.formatMessage({defaultMessage:"I want to get a handle on my calendar. Check if Google Calendar\u2019s connected first since it\u2019ll help pull in what\u2019s actually there. If not, I\u2019ll describe my week and what\u2019s not working. Follow up on anything that\u2019s unclear, then show me where my time is going and what to change.",id:"9AWyVQgY9+"}),tags:["calendar","schedule","productivity","time manage